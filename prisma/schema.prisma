
generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role{
  User
  Admin
}

model Users {
  id String @default(uuid()) @id
  role Role @default(User)
  DisplayName String?
  email String @unique
  Hashpassword String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cart cart[]
  address Address[]
}

model category{
  id String @default(uuid()) @id
  name String
  slug String @unique
  createdAt DateTime @default(now()) 
  products product[]
}

model product {
  id String @default(uuid()) @id
  categoryId String
  name String
  prodImage String
  price Decimal
  slug String @unique
  isPublished Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  category category @relation(references: [id], fields: [categoryId], onDelete: Cascade)
  productvariant ProductVariant[]

  @@index([id,name,prodImage,categoryId,price,slug,isPublished])
}

model ProductVariant{
  id String @default(uuid()) @id
  productId String
  size String
  stockQuantity Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  cart cart[]
  product product @relation(references: [id], fields: [productId], onDelete: Cascade) 
  @@unique([productId, size])
  @@index([productId])
}

model cart {
  id String @default(uuid()) @id
  userId String
  productVariantId String
  quantity Int
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@unique([userId, productVariantId])

  @@index([userId])

  user Users @relation(references: [id], fields: [userId], onDelete: Cascade)
  productvariant ProductVariant @relation(references: [id], fields: [productVariantId], onDelete: Cascade)
}

model Address{
  id String @default(uuid()) @id
  isDefault Boolean @default(false)
  phoneNumber String
  userId String
  fullName String
  Country String
  AddressLine1 String
  AddressLine2 String?
  City String
  State String
  pincode String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user Users @relation(references: [id], fields: [userId], onDelete: Cascade) 
}